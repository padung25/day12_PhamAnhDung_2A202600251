# Copy this file to cloudrun.env.yaml and fill real values before deploying.
# Do not commit cloudrun.env.yaml.
#
# Cloud Run sets PORT automatically. Do not put PORT in this file.

HOST: "0.0.0.0"
ENVIRONMENT: "production"
DEBUG: "false"

APP_NAME: "Production AI Agent"
APP_VERSION: "1.0.0"
LOG_LEVEL: "INFO"

# Leave empty when using the mock LLM.
OPENAI_API_KEY: ""
LLM_MODEL: "gpt-4o-mini"

# Replace with strong secrets in real deployment.
AGENT_API_KEY: "replace-with-your-agent-api-key"
JWT_SECRET: "replace-with-your-jwt-secret"

RATE_LIMIT_PER_MINUTE: "10"
MONTHLY_BUDGET_USD: "10.0"
COST_PER_REQUEST_USD: "0.01"

# Cloud Run cannot use redis://redis:6379/0 or redis://localhost:6379/0.
# Use a managed Redis URL, for example Upstash rediss://... or Memorystore redis://10.x.x.x:6379/0.
REDIS_URL: "replace-with-your-managed-redis-url"

ALLOWED_ORIGINS: "*"

